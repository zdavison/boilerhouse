{
  "name": "@boilerhouse/cli",
  "version": "0.1.8",
  "private": true,
  "license": "BUSL-1.1",
  "type": "module",
  "exports": {
    ".": "./src/main.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build --compile src/main.ts --outfile ../../dist/boilerhouse",
    "build:linux-amd64": "bun build --compile --target=bun-linux-x64 src/main.ts --outfile ../../dist/boilerhouse-linux-amd64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/main.ts --outfile ../../dist/boilerhouse-linux-arm64"
  },
  "dependencies": {
    "@boilerhouse/api": "workspace:*",
    "@boilerhouse/core": "workspace:*",
    "commander": "^13.1.0"
  }
}
