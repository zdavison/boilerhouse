{
  "name": "@boilerhouse/trigger-gateway",
  "version": "0.1.9",
  "private": true,
  "license": "BUSL-1.1",
  "type": "module",
  "exports": {
    ".": "./src/server.ts"
  },
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "start": "bun src/server.ts",
    "build": "bun build --compile src/server.ts --outfile ../../dist/trigger-gateway",
    "build:linux-amd64": "bun build --compile --target=bun-linux-x64 src/server.ts --outfile ../../dist/trigger-gateway-linux-amd64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/server.ts --outfile ../../dist/trigger-gateway-linux-arm64"
  },
  "dependencies": {
    "@boilerhouse/o11y": "workspace:*",
    "@boilerhouse/triggers": "workspace:*",
    "elysia": "^1.4.25"
  }
}
