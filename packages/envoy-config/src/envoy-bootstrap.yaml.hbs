admin:
  address:
    socket_address:
      address: 127.0.0.1
      port_value: {{adminPort}}

static_resources:
  listeners:
  - name: egress_proxy
    address:
      socket_address:
        address: 127.0.0.1
        port_value: {{port}}
    filter_chains:
    - filters:
      - name: envoy.filters.network.http_connection_manager
        typed_config:
          "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
          stat_prefix: egress_proxy
          http_protocol_options:
            allow_absolute_url: true
          route_config:
            name: local_route
            virtual_hosts:
{{#each domains}}
            - name: {{safeName domain}}
              domains:
              - "{{domain}}"
              routes:
              - match:
                  prefix: /
{{#if isWildcard}}
                direct_response:
                  status: 502
                  body:
                    inline_string: "Wildcard domain matched but dynamic forward proxy is not yet configured"
{{else}}
                route:
                  cluster: upstream_{{safeName domain}}
{{#if headers}}
                request_headers_to_add:
{{#each headers}}
                - header:
                    key: "{{key}}"
                    value: "{{value}}"
                  append_action: OVERWRITE_IF_EXISTS_OR_ADD
{{/each}}
{{/if}}
{{/if}}
{{/each}}
            - name: deny_all
              domains:
              - "*"
              routes:
              - match:
                  prefix: /
                direct_response:
                  status: 403
                  body:
                    inline_string: "Forbidden: domain not in allowlist"
          http_filters:
          - name: envoy.filters.http.router
            typed_config:
              "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router

  clusters:
{{#each clusters}}
  - name: upstream_{{safeName domain}}
    type: STRICT_DNS
    transport_socket:
      name: envoy.transport_sockets.tls
      typed_config:
        "@type": type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.UpstreamTlsContext
        sni: {{domain}}
    load_assignment:
      cluster_name: upstream_{{safeName domain}}
      endpoints:
      - lb_endpoints:
        - endpoint:
            address:
              socket_address:
                address: {{domain}}
                port_value: 443
{{/each}}
